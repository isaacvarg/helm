generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Dashboard {
  id                Int     @id @default(1)
  title             String
  subtitle          String
  titleGradientFrom String
  titleGradientVia  String?
  titleGradientTo   String
  backgroundImage   String
  bgOverlayFrom     String
  bgOverlayVia      String?
  bgOverlayTo       String
  bgOverlayOpacity  Float   @default(1)
  theme             String  @default("mocha")
  tabs              Tab[]
}

model Tab {
  id               Int       @id @default(autoincrement())
  dashboardId      Int
  dashboard        Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  slug             String    @unique
  label            String
  icon             String
  order            Int
  pillGradientFrom String
  pillGradientTo   String
  sideImage        String
  sideImageAlt     String
  sideImageEdge    String
  showSideImage    Boolean @default(true)
  bgColor          String?
  bgOpacity        Float   @default(1)
  bgImage          String?
  borderWidth      Int     @default(0)
  borderStyle      String  @default("solid")
  borderColor      String?
  sectionColumns   Int     @default(1)
  linkColumns      Int     @default(2)
  headerTitle      String  @default("")
  headerVAlign     String  @default("top")
  headerHAlign     String  @default("center")
  headerColor      String?
  headerSize       String  @default("2xl")
  headerWeight     String  @default("bold")
  pillBgColor      String?
  pillBgOpacity    Float   @default(1)
  pillBgImage      String?
  pillShowIcon     Boolean @default(true)
  pillShowTitle    Boolean @default(true)
  pillTitleColor   String?
  pillTitleSize    String  @default("sm")
  pillTitleWeight  String  @default("medium")
  sections         Section[]
}

model Section {
  id    Int    @id @default(autoincrement())
  tabId Int
  tab   Tab    @relation(fields: [tabId], references: [id], onDelete: Cascade)
  title String
  icon  String
  order Int
  showIcon    Boolean @default(true)
  showTitle   Boolean @default(true)
  iconSize    String  @default("sm")
  titleSize   String  @default("xs")
  titleWeight String  @default("semibold")
  titleColor  String?
  borderWidth Int     @default(0)
  borderStyle String  @default("solid")
  borderColor String?
  bgColor     String?
  bgOpacity   Float   @default(1)
  bgImage     String?
  links Link[]
}

model Link {
  id          Int     @id @default(autoincrement())
  sectionId   Int
  section     Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  icon        String
  title       String
  description String?
  href        String
  newTab      Boolean @default(true)
  showIcon        Boolean @default(true)
  showTitle       Boolean @default(true)
  showDescription Boolean @default(true)
  bgColor   String?
  bgOpacity Float   @default(1)
  bgImage   String?
  borderWidth Int     @default(0)
  borderStyle String  @default("solid")
  borderColor String?
  textAlign String  @default("left")
  titleSize   String @default("sm")
  titleWeight String @default("medium")
  textColor   String?
  order       Int
}
